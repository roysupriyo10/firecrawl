# Copy to .env.deploy (gitignored) or export before running scripts/deploy-selfhost.sh
#
# YOUR registry only — never ghcr.io/firecrawl (that's Firecrawl's official images).
#
# FIRECRAWL_REGISTRY_TOKEN is a GitHub credential that can push/pull packages on GHCR.
# Easiest: leave it empty and run once (browser approval):
#   gh auth refresh -h github.com -s read:packages,write:packages
# The deploy script then uses `gh auth token` automatically.
#
# Or create a classic PAT: https://github.com/settings/tokens
#   Generate new token (classic) → enable read:packages + write:packages
#   Paste into FIRECRAWL_REGISTRY_TOKEN below (do not commit).

FIRECRAWL_REGISTRY=ghcr.io/roysupriyo10
FIRECRAWL_TAG=latest
FIRECRAWL_REGISTRY_USER=roysupriyo10
FIRECRAWL_REGISTRY_TOKEN=

FIRECRAWL_BUILDX_BUILDER=firecrawl-builder

# Build optimizations
FIRECRAWL_BUILD_PARALLEL=1
FIRECRAWL_SKIP_CACHE=0
FIRECRAWL_IMAGES=api,playwright,nuq-postgres
FIRECRAWL_DETACH=1
# FIRECRAWL_PLATFORM=linux/amd64
# Resume partial: FIRECRAWL_IMAGES=playwright,nuq-postgres
